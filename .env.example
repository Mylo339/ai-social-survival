# Optional OpenAI-compatible chat-completions endpoint.
# Keep this file as an example only. Never commit real API keys.
AI_ENDPOINT=https://your-provider.example/v1/chat/completions
AI_API_KEY=replace-with-server-side-secret
AI_MODEL=replace-with-model-name
AI_THINKING=disabled

# Cost and abuse guardrails for public beta.
AI_TURN_RATE_LIMIT_PER_MINUTE=18
FEEDBACK_RATE_LIMIT_PER_MINUTE=20
EVENT_RATE_LIMIT_PER_MINUTE=140

# Public deployment can override these.
HOST=127.0.0.1
PORT=4177
DATA_DIRECTORY=./data
